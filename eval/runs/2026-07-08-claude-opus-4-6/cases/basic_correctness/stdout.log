{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01Y3ogoetxByDejfUa36dfUr","type":"tool_result","content":"1\t# SPDX-License-Identifier: Apache-2.0\n2\t# SPDX-FileCopyrightText: Copyright contributors to the vLLM project\n3\t\n4\timport asyncio\n5\t\n6\timport pytest\n7\timport torch\n8\t\n9\tfrom vllm import LLM, AsyncEngineArgs, AsyncLLMEngine, SamplingParams\n10\tfrom vllm.device_allocator import get_mem_allocator_instance\n11\tfrom vllm.platforms import current_platform\n12\tfrom vllm.utils.mem_constants import GiB_bytes\n13\t\n14\tfrom ..utils import create_new_process_for_each_test, requires_fp8\n15\t\n16\tDEVICE_TYPE = current_platform.device_type\n17\t\n18\t\n19\t@create_new_process_for_each_test(\"fork\" if current_platform.is_cuda() else \"spawn\")\n20\tdef test_python_error():\n21\t    \"\"\"\n22\t    Test if Python error occurs when there's low-level\n23\t    error happening from the C++ side.\n24\t    \"\"\"\n25\t    allocator = get_mem_allocator_instance()\n26\t    total_bytes = current_platform.mem_get_info()[1]\n27\t    alloc_bytes = int(total_bytes * 0.7)\n28\t    tensors = []\n29\t    with allocator.use_memory_pool():\n30\t        # allocate 70% of the total memory\n31\t        x = torch.empty(alloc_bytes, dtype=torch.uint8, device=DEVICE_TYPE)\n32\t        tensors.append(x)\n33\t    # release the memory\n34\t    allocator.sleep()\n35\t\n36\t    # allocate more memory than the total memory\n37\t    y = torch.empty(alloc_bytes, dtype=torch.uint8, device=DEVICE_TYPE)\n38\t    tensors.append(y)\n39\t    with pytest.raises(RuntimeError):\n40\t        # when the allocator is woken up, it should raise an error\n41\t        # because we don't have enough memory\n42\t        allocator.wake_up()\n43\t\n44\t\n45\t@create_new_process_for_each_test(\"fork\" if current_platform.is_cuda() else \"spawn\")\n46\tdef test_basic_cumem():\n47\t    # some tensors from default memory pool\n48\t    shape = (1024, 1024)\n49\t    x = torch.empty(shape, device=DEVICE_TYPE)\n50\t    x.zero_()\n51\t\n52\t    # some tensors from custom memory pool\n53\t    allocator = get_mem_allocator_instance()\n54\t    with allocator.use_memory_pool():\n55\t        # custom memory pool\n56\t        y = torch.empty(shape, device=DEVICE_TYPE)\n57\t        y.zero_()\n58\t        y += 1\n59\t        z = torch.empty(shape, device=DEVICE_TYPE)\n60\t        z.zero_()\n61\t        z += 2\n62\t\n63\t    # they can be used together\n64\t    output = x + y + z\n65\t    assert torch.allclose(output, torch.ones_like(output) * 3)\n66\t\n67\t    free_bytes = current_platform.mem_get_info()[0]\n68\t    allocator.sleep()\n69\t    free_bytes_after_sleep = current_platform.mem_get_info()[0]\n70\t    assert free_bytes_after_sleep > free_bytes\n71\t    allocator.wake_up()\n72\t\n73\t    # they can be used together\n74\t    output = x + y + z\n75\t    assert torch.allclose(output, torch.ones_like(output) * 3)\n76\t\n77\t\n78\t@create_new_process_for_each_test(\"fork\" if current_platform.is_cuda() else \"spawn\")\n79\t@pytest.mark.skipif(current_platform.is_xpu(), reason=\"CUDA graph not supported on XPU\")\n80\tdef test_cumem_with_cudagraph():\n81\t    allocator = get_mem_allocator_instance()\n82\t    with allocator.use_memory_pool():\n83\t        weight = torch.eye(1024, device=DEVICE_TYPE)\n84\t    with allocator.use_memory_pool(tag=\"discard\"):\n85\t        cache = torch.empty(1024, 1024, device=DEVICE_TYPE)\n86\t\n87\t    def model(x):\n88\t        out = x @ weight\n89\t        cache[: out.size(0)].copy_(out)\n90\t        return out + 1\n91\t\n92\t    x = torch.empty(128, 1024, device=DEVICE_TYPE)\n93\t\n94\t    # warmup\n95\t    model(x)\n96\t\n97\t    # capture cudagraph\n98\t    model_graph = torch.cuda.CUDAGraph()\n99\t    with torch.cuda.graph(model_graph):\n100\t        y = model(x)\n101\t\n102\t    free_bytes = current_platform.mem_get_info()[0]\n103\t    allocator.sleep()\n104\t    free_bytes_after_sleep = current_platform.mem_get_info()[0]\n105\t    assert free_bytes_after_sleep > free_bytes\n106\t    allocator.wake_up()\n107\t\n108\t    # after waking up, the content in the weight tensor\n109\t    # should be restored, but the content in the cache tensor\n110\t    # should be discarded\n111\t\n112\t    # this operation is also compatible with cudagraph\n113\t\n114\t    x.random_()\n115\t    model_graph.replay()\n116\t\n117\t    # cache content is as expected\n118\t    assert torch.allclose(x, cache[: x.size(0)])\n119\t\n120\t    # output content is as expected\n121\t    assert torch.allclose(y, x + 1)\n122\t\n123\t\n124\t@create_new_process_for_each_test(\"fork\" if current_platform.is_cuda() else \"spawn\")\n125\t@pytest.mark.parametrize(\n126\t    \"model\",\n127\t    [\n128\t        # sleep mode with safetensors\n129\t        \"hmellor/tiny-random-LlamaForCausalLM\",\n130\t        # sleep mode with pytorch checkpoint\n131\t        \"facebook/opt-125m\",\n132\t    ],\n133\t)\n134\tdef test_end_to_end(model: str):\n135\t    free, total = current_platform.mem_get_info()\n136\t    used_bytes_baseline = total - free  # in case other process is running\n137\t    llm = LLM(model, enable_sleep_mode=True)\n138\t    prompt = \"How are you?\"\n139\t    sampling_params = SamplingParams(temperature=0, max_tokens=10)\n140\t    output = llm.generate(prompt, sampling_params)\n141\t\n142\t    # the benefit of `llm.sleep(level=2)` is mainly CPU memory usage,\n143\t    # which is difficult to measure in the test. therefore, we only\n144\t    # test sleep level 1 here.\n145\t    llm.sleep(level=1)\n146\t\n147\t    free_gpu_bytes_after_sleep, total = current_platform.mem_get_info()\n148\t    used_bytes = total - free_gpu_bytes_after_sleep - used_bytes_baseline\n149\t    # now the memory usage is mostly cudagraph memory pool,\n150\t    # and it should be less than the model weights (1B model, 2GiB weights)\n151\t\n152\t    # NOTE: In V1, the memory buffer for logits (max_num_reqs x vocab_size)\n153\t    # is captured but cannot be releasesd from PyTorch due to a known bug,\n154\t    # therefore high memory usage after `llm.sleep` is called is expected.\n155\t    # FIXME(youkaichao & ywang96): Fix memory buffer issue with sleep mode\n156\t    # in V1.\n157\t    assert used_bytes < 7 * GiB_bytes\n158\t\n159\t    llm.wake_up()\n160\t    output2 = llm.generate(prompt, sampling_params)\n161\t    # cmp output\n162\t    assert output[0].outputs[0].text == output2[0].outputs[0].text\n163\t\n164\t    llm.sleep(level=1)\n165\t    llm.wake_up(tags=[\"weights\"])\n166\t\n167\t    free_gpu_bytes_wake_up_w, total = current_platform.mem_get_info()\n168\t    used_bytes = total - free_gpu_bytes_wake_up_w - used_bytes_baseline\n169\t\n170\t    # should just reallocate memory for weights (1B model, ~2GiB weights)\n171\t    assert used_bytes < 10 * GiB_bytes\n172\t\n173\t    # now allocate kv cache memory\n174\t    llm.wake_up(tags=[\"kv_cache\"])\n175\t    output3 = llm.generate(prompt, sampling_params)\n176\t\n177\t    # cmp output\n178\t    assert output[0].outputs[0].text == output3[0].outputs[0].text\n179\t\n180\t\n181\t@create_new_process_for_each_test()\n182\tdef test_deep_sleep():\n183\t    model = \"hmellor/tiny-random-LlamaForCausalLM\"\n184\t    free, total = current_platform.mem_get_info()\n185\t    used_bytes_baseline = total - free  # in case other process is running\n186\t    llm = LLM(model, enable_sleep_mode=True)\n187\t    prompt = \"How are you?\"\n188\t    sampling_params = SamplingParams(temperature=0, max_tokens=10)\n189\t    output = llm.generate(prompt, sampling_params)\n190\t\n191\t    # Put the engine to deep sleep\n192\t    llm.sleep(level=2)\n193\t\n194\t    free_gpu_bytes_after_sleep, total = current_platform.mem_get_info()\n195\t    used_bytes = total - free_gpu_bytes_after_sleep - used_bytes_baseline\n196\t    assert used_bytes < 3 * GiB_bytes\n197\t\n198\t    llm.wake_up(tags=[\"weights\"])\n199\t    llm.collective_rpc(\"reload_weights\")\n200\t    free_gpu_bytes_wake_up_w, total = current_platform.mem_get_info()\n201\t    used_bytes = total - free_gpu_bytes_wake_up_w - used_bytes_baseline\n202\t    assert used_bytes < 4 * GiB_bytes\n203\t\n204\t    # now allocate kv cache and cuda graph memory\n205\t    llm.wake_up(tags=[\"kv_cache\"])\n206\t    output2 = llm.generate(prompt, sampling_params)\n207\t\n208\t    # cmp output\n209\t    assert output[0].outputs[0].text == output2[0].outputs[0].text\n210\t\n211\t\n212\t@create_new_process_for_each_test()\n213\tdef test_deep_sleep_async():\n214\t    async def test():\n215\t        model = \"hmellor/tiny-random-LlamaForCausalLM\"\n216\t        free, total = current_platform.mem_get_info()\n217\t        used_bytes_baseline = total - free  # in case other process is running\n218\t        engine_args = AsyncEngineArgs(\n219\t            model=model,\n220\t            enable_sleep_mode=True,\n221\t        )\n222\t\n223\t        llm = AsyncLLMEngine.from_engine_args(engine_args)\n224\t        prompt = \"How are you?\"\n225\t        sampling_params = SamplingParams(temperature=0, max_tokens=10)\n226\t        outputs = llm.generate(prompt, sampling_params, request_id=\"test_request_id1\")\n227\t        async for output in outputs:\n228\t            pass\n229\t\n230\t        # Put the engine to deep sleep\n231\t        await llm.sleep(level=2)\n232\t\n233\t        await llm.wake_up(tags=[\"weights\"])\n234\t        await llm.collective_rpc(\"reload_weights\")\n235\t        free_gpu_bytes_wake_up_w, total = current_platform.mem_get_info()\n236\t        used_bytes = total - free_gpu_bytes_wake_up_w - used_bytes_baseline\n237\t        assert used_bytes < 4 * GiB_bytes\n238\t\n239\t        # now allocate kv cache and cuda graph memory\n240\t        await llm.wake_up(tags=[\"kv_cache\"])\n241\t        outputs2 = llm.generate(prompt, sampling_params, request_id=\"test_request_id2\")\n242\t        async for output2 in outputs2:\n243\t            pass\n244\t\n245\t        # cmp output\n246\t        assert output.outputs[0].text == output2.outputs[0].text\n247\t\n248\t    asyncio.run(test())\n249\t\n250\t\n251\t@requires_fp8\n252\tdef test_deep_sleep_fp8_kvcache():\n253\t    model = \"Qwen/Qwen2-0.5B\"\n254\t    used_bytes_baseline = current_platform.get_current_memory_usage()\n255\t\n256\t    llm = LLM(model, enable_sleep_mode=True, kv_cache_dtype=\"fp8\")\n257\t    prompt = \"How are you?\"\n258\t    sampling_params = SamplingParams(temperature=0, max_tokens=10)\n259\t    output = llm.generate(prompt, sampling_params)\n260\t\n261\t    # Put the engine to deep sleep\n262\t    llm.sleep(level=2)\n263\t\n264\t    used_bytes = current_platform.get_current_memory_usage() - used_bytes_baseline\n265\t\n266\t    # Rocm uses more memory for CudaGraphs, so we add 2 GiB more for the threshold\n267\t    rocm_extra_mem_bytes = 2 * GiB_bytes if current_platform.is_rocm() else 0\n268\t    mem_threshold_after_sleep = 3 * GiB_bytes + rocm_extra_mem_bytes\n269\t    assert used_bytes < mem_threshold_after_sleep\n270\t\n271\t    llm.wake_up(tags=[\"weights\"])\n272\t    llm.collective_rpc(\"reload_weights\")\n273\t\n274\t    used_bytes = current_platform.get_current_memory_usage() - used_bytes_baseline\n275\t    mem_threshold_after_wake_up = 4 * GiB_bytes + rocm_extra_mem_bytes\n276\t    assert used_bytes < mem_threshold_after_wake_up\n277\t\n278\t    # now allocate kv cache and cuda graph memory\n279\t    llm.wake_up(tags=[\"kv_cache\"])\n280\t    output2 = llm.generate(prompt, sampling_params)\n281\t\n282\t    # cmp output\n283\t    assert output[0].outputs[0].text == output2[0].outputs[0].text\n284\t"}]},"parent_tool_use_id":"toolu_vrtx_01JVLZeSgRLA7Js8E4G1ZQCd","session_id":"a1879361-8ad3-49bc-ad0d-bf78fd163104","uuid":"5df64f22-fd3d-46dd-9c86-42ce79d0c305","timestamp":"2026-07-08T18:26:32.076Z","subagent_type":"vllm-test-audit:audit-agent","task_description":"Audit vLLM basic_correctness tests"}
