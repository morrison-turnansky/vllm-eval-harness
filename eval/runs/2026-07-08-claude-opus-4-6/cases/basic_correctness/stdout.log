{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_0149kM4Aty1TjyjX2hZVwN8q","type":"tool_result","content":"906\tdef _test_completion(\n907\t    client: openai.OpenAI,\n908\t    model: str,\n909\t    prompt: str,\n910\t    token_ids: list[int],\n911\t    include_seeded_sampling: bool = True,\n912\t):\n913\t    results = []\n914\t\n915\t    # test with text prompt\n916\t    completion = client.completions.create(\n917\t        model=model, prompt=prompt, max_tokens=5, temperature=0.0\n918\t    )\n919\t\n920\t    results.append(\n921\t        {\n922\t            \"test\": \"single_completion\",\n923\t            \"text\": completion.choices[0].text,\n924\t            \"finish_reason\": completion.choices[0].finish_reason,\n925\t            \"usage\": completion.usage,\n926\t        }\n927\t    )\n928\t\n929\t    # test using token IDs\n930\t    completion = client.completions.create(\n931\t        model=model,\n932\t        prompt=token_ids,\n933\t        max_tokens=5,\n934\t        temperature=0.0,\n935\t    )\n936\t\n937\t    results.append(\n938\t        {\n939\t            \"test\": \"token_ids\",\n940\t            \"text\": completion.choices[0].text,\n941\t            \"finish_reason\": completion.choices[0].finish_reason,\n942\t            \"usage\": completion.usage,\n943\t        }\n944\t    )\n945\t\n946\t    if include_seeded_sampling:\n947\t        # test seeded random sampling\n948\t        completion = client.completions.create(\n949\t            model=model, prompt=prompt, max_tokens=5, seed=33, temperature=1.0\n950\t        )\n951\t\n952\t        results.append(\n953\t            {\n954\t                \"test\": \"seeded_sampling\",\n955\t                \"text\": completion.choices[0].text,\n956\t                \"finish_reason\": completion.choices[0].finish_reason,\n957\t                \"usage\": completion.usage,\n958\t            }\n959\t        )\n960\t\n961\t        # test seeded random sampling with multiple prompts\n962\t        completion = client.completions.create(\n963\t            model=model,\n964\t            prompt=[prompt, prompt],\n965\t            max_tokens=5,\n966\t            seed=33,\n967\t            temperature=1.0,\n968\t        )\n969\t\n970\t        results.append(\n971\t            {\n972\t                \"test\": \"seeded_sampling\",\n973\t                \"text\": [choice.text for choice in completion.choices],\n974\t                \"finish_reason\": [\n975\t                    choice.finish_reason for choice in completion.choices\n976\t                ],\n977\t                \"usage\": completion.usage,\n978\t            }\n979\t        )\n980\t\n981\t    # test simple list\n982\t    batch = client.completions.create(\n983\t        model=model,\n984\t        prompt=[prompt, prompt],\n985\t        max_tokens=5,\n986\t        temperature=0.0,\n987\t    )\n988\t\n989\t    results.append(\n990\t        {\n991\t            \"test\": \"simple_list\",\n992\t            \"text0\": batch.choices[0].text,\n993\t            \"text1\": batch.choices[1].text,\n994\t        }\n995\t    )\n996\t\n997\t    # test streaming\n998\t    batch = client.completions.create(\n999\t        model=model,\n1000\t        prompt=[prompt, prompt],\n1001\t        max_tokens=5,\n1002\t        temperature=0.0,\n1003\t        stream=True,\n1004\t    )\n1005\t\n1006\t    texts = [\"\"] * 2\n1007\t    for chunk in batch:\n1008\t        assert len(chunk.choices) == 1\n1009\t        choice = chunk.choices[0]\n1010\t        texts[choice.index] += choice.text\n1011\t\n1012\t    results.append(\n1013\t        {\n1014\t            \"test\": \"streaming\",\n1015\t            \"texts\": texts,\n1016\t        }\n1017\t    )\n1018\t\n1019\t    return results\n1020\t\n1021\t\n1022\tdef _test_completion_close(\n1023\t    client: openai.OpenAI,\n1024\t    model: str,\n1025\t    prompt: str,"}]},"parent_tool_use_id":"toolu_vrtx_01JVLZeSgRLA7Js8E4G1ZQCd","session_id":"a1879361-8ad3-49bc-ad0d-bf78fd1