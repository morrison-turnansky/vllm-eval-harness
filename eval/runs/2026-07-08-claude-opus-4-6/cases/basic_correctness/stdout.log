{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01SjHbMkUtgYC7BTgL9Bkmx3","type":"tool_result","content":"1\t# SPDX-License-Identifier: Apache-2.0\n2\t# SPDX-FileCopyrightText: Copyright contributors to the vLLM project\n3\t\"\"\"Test prefetch offloading correctness with Llama model.\"\"\"\n4\t\n5\tfrom ..utils import compare_two_settings\n6\t\n7\t\n8\tdef test_prefetch_offload_llama():\n9\t    \"\"\"Test prefetch CPU offloading with Llama-3.2-1B-Instruct.\n10\t\n11\t    Compares outputs between:\n12\t    1. Baseline (no offloading)\n13\t    2. Prefetch offloading (group_size=8, num_in_group=2, prefetch_step=1)\n14\t\n15\t    This tests prefetching-based offloading on a dense model.\n16\t    \"\"\"\n17\t    compare_two_settings(\n18\t        \"meta-llama/Llama-3.2-1B-Instruct\",\n19\t        [\n20\t            # Prefetch offloading configuration\n21\t            \"--offload-group-size\",\n22\t            \"8\",\n23\t            \"--offload-num-in-group\",\n24\t            \"2\",\n25\t            \"--offload-prefetch-step\",\n26\t            \"1\",\n27\t            # Selective offloading: only MLP weights\n28\t            \"--offload-params\",\n29\t            \"gate_up_proj\",\n30\t            \"down_proj\",\n31\t        ],\n32\t        [],  # Baseline: no offloading\n33\t    )\n34\t"}]},"parent_tool_use_id":"toolu_vrtx_01JVLZeSgRLA7Js8E4G1ZQCd","session_id":"a1879361-8ad3-49bc-ad0d-bf78fd163104","uuid":"07dba282-3230-4a9f-80ae-addbd7d004b4","timestamp":"2026-07-08T18:26:32.518Z","subagent_type":"vllm-test-audit:audit-agent","task_description":"Audit vLLM basic_correctness tests"}
