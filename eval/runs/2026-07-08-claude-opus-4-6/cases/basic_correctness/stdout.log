{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01ByA4rVfSMYQr3PtxKaUQfr","type":"tool_result","content":"1\t# SPDX-License-Identifier: Apache-2.0\n2\t# SPDX-FileCopyrightText: Copyright contributors to the vLLM project\n3\t\n4\timport pytest\n5\t\n6\tfrom ..utils import compare_two_settings\n7\t\n8\t\n9\t@pytest.mark.parametrize(\"disable_pin_memory\", [False, True])\n10\t@pytest.mark.parametrize(\"disable_uva\", [False, True])\n11\tdef test_cpu_offload(disable_pin_memory, disable_uva):\n12\t    env_vars = {\n13\t        \"VLLM_WEIGHT_OFFLOADING_DISABLE_PIN_MEMORY\": str(int(disable_pin_memory)),\n14\t        \"VLLM_WEIGHT_OFFLOADING_DISABLE_UVA\": str(int(disable_uva)),\n15\t    }\n16\t\n17\t    args = [\"--cpu-offload-gb\", \"1\"]\n18\t\n19\t    # cuda graph only works with UVA offloading\n20\t    if disable_uva:\n21\t        args.append(\"--enforce-eager\")\n22\t\n23\t    compare_two_settings(\n24\t        model=\"hmellor/tiny-random-LlamaForCausalLM\",\n25\t        arg1=[],\n26\t        arg2=args,\n27\t        env1=None,\n28\t        env2=env_vars,\n29\t    )\n30\t"}]},"parent_tool_use_id":"toolu_vrtx_01JVLZeSgRLA7Js8E4G1ZQCd","session_id":"a1879361-8ad3-49bc-ad0d-bf78fd163104","uuid":"bf59c4a0-929b-48c3-97b6-574bc9cdbdf5","timestamp":"2026-07-08T18:26:31.739Z","subagent_type":"vllm-test-audit:audit-agent","task_description":"Audit vLLM basic_correctness tests"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01QbksFXdj4DxpXtn8YWu7Be","type":"tool_result","content":"1\t# SPDX-License-Identifier: Apache-2.0\n2\t# SPDX-FileCopyrightText: Copyright contributors to the vLLM project\n3\t\"\"\"Compare the short outputs of HF and vLLM when using greedy sampling.\n4\t\n5\tRun `pytest tests/basic_correctness/test_basic_correctness.py`.\n6\t\"\"\"\n7\t\n8\timport os\n9\timport weakref\n10\tfrom unittest.mock import Mock\n11\t\n12\timport pytest\n13\timport torch\n14\tfrom packaging.version import Version\n15\tfrom transformers import __version__ as TRANSFORMERS_VERSION\n16\t\n17\tfrom vllm import LLM\n18\tfrom vllm.platforms import current_platform\n19\tfrom vllm.v1.engine.llm_engine import LLMEngine\n20\t\n21\tfrom ..conftest import HfRunner, VllmRunner\n22\tfrom ..models.utils import check_outputs_equal\n23\tfrom ..utils import multi_gpu_test\n24\t\n25\tATTN_BACKEND = [\"ROCM_ATTN\"] if current_platform.is_rocm() else [\"FLASH_ATTN\"]\n26\t\n27\tMODELS = [\n28\t    \"hmellor/tiny-random-Gemma2ForCausalLM\",\n29\t    \"meta-llama/Llama-3.2-1B-Instruct\",\n30\t]\n31\t\n32\tTARGET_TEST_SUITE = os.environ.get(\"TARGET_TEST_SUITE\", \"L4\")\n33\t\n34\t\n35\tdef test_vllm_gc_ed():\n36\t    \"\"\"Verify vllm instance is GC'ed when it is deleted\"\"\"\n37\t    llm = LLM(\"hmellor/tiny-random-LlamaForCausalLM\")\n38\t    weak_llm = weakref.ref(llm)\n39\t    del llm\n40\t    # If there's any circular reference to vllm, this fails\n41\t    # because llm instance is not GC'ed.\n42\t    assert weak_llm() is None\n43\t\n44\t\n45\tdef _fix_prompt_embed_outputs(\n46\t    vllm_outputs: list[tuple[list[int], str]],\n47\t    hf_model: HfRunner,\n48\t    example_prompts: list[str],\n49\t) -> list[tuple[list[int], str]]:\n50\t    fixed_vllm_outputs = []\n51\t    for vllm_output, hf_input, prompt in zip(\n52\t        vllm_outputs, hf_model.get_inputs(example_prompts), example_prompts\n53\t    ):\n54\t        hf_input_ids = hf_input[\"input_ids\"].tolist()[0]\n55\t        fixed_vllm_outputs.append(\n56\t            (\n57\t                hf_input_ids + vllm_output[0][len(hf_input_ids) :],\n58\t                prompt + vllm_output[1],\n59\t            )\n60\t        )\n61\t    return fixed_vllm_outputs\n62\t\n63\t\n64\t@pytest.mark.parametrize(\"model\", MODELS)\n65\t@pytest.mark.parametrize(\"backend\", ATTN_BACKEND)\n66\t@pytest.mark.parametrize(\"max_tokens\", [5])\n67\t@pytest.mark.parametrize(\"enforce_eager\", [False])\n68\t@pytest.mark.parametrize(\"async_scheduling\", [True, False])\n69\t@pytest.mark.parametrize(\"model_executor\", [\"uni\", \"mp\"])\n70\t@pytest.mark.parametrize(\"enable_prompt_embeds\", [True, False])\n71\tdef test_models(\n72\t    hf_runner,\n73\t    model: str,\n74\t    backend: str,\n75\t    max_tokens: int,\n76\t    enforce_eager: bool,\n77\t    async_scheduling: bool,\n78\t    model_executor: str,\n79\t    enable_prompt_embeds: bool,\n80\t) -> None:\n81\t    # 5042 tokens for gemma2\n82\t    # gemma2 has alternating sliding window size of 4096\n83\t    # we need a prompt with more than 4096 tokens to test the sliding window\n84\t    prompt = (\n85\t        \"The following numbers of the sequence \"\n86\t        + \", \".join(str(i) for i in range(1024))\n87\t        + \" are:\"\n88\t    )\n89\t    example_prompts = [prompt]\n90\t\n91\t    with hf_runner(model) as hf_model:\n92\t        hf_outputs = hf_model.generate_greedy(example_prompts, max_tokens)\n93\t        if enable_prompt_embeds:\n94\t            with torch.no_grad():\n95\t                prompt_embeds = hf_model.get_prompt_embeddings(example_prompts)\n96\t            if model == \"hmellor/tiny-random-Gemma2ForCausalLM\" and (\n97\t                Version(TRANSFORMERS_VERSION) < Version(\"5.3.0.dev0\")\n98\t            ):\n99\t                # For Gemma 1/2 models with Transformers 5.4.0+, the prompt embeddings\n100\t                # are normalised in `get_prompt_embeddings`, like Gemma 3.\n101\t                # For older versions, we need to manually normalise.\n102\t                embed_scale = hf_model.config.hidden_size**0.5\n103\t                normalizer = torch.tensor(embed_scale, dtype=prompt_embeds[0].dtype)\n104\t                prompt_embeds = [p_e * normalizer for p_e in prompt_embeds]\n105\t\n106\t    with VllmRunner(\n107\t        model,\n108\t        max_model_len=8192,\n109\t        enforce_eager=enforce_eager,\n110\t        enable_prompt_embeds=enable_prompt_embeds,\n111\t        gpu_memory_utilization=0.7,\n112\t        async_scheduling=async_scheduling,\n113\t        distributed_executor_backend=model_executor,\n114\t        attention_config={\"backend\": backend},\n115\t    ) as vllm_model:\n116\t        if enable_prompt_embeds:\n117\t            vllm_outputs = vllm_model.generate_greedy(prompt_embeds, max_tokens)\n118\t            vllm_outputs = _fix_prompt_embed_outputs(\n119\t                vllm_outputs, hf_model, example_prompts\n120\t            )\n121\t        else:\n122\t            vllm_outputs = vllm_model.generate_greedy(example_prompts, max_tokens)\n123\t\n124\t    check_outputs_equal(\n125\t        outputs_0_lst=hf_outputs,\n126\t        outputs_1_lst=vllm_outputs,\n127\t        name_0=\"hf\",\n128\t        name_1=\"vllm\",\n129\t    )\n130\t\n131\t\n132\t@multi_gpu_test(num_gpus=2)\n133\t@pytest.mark.parametrize(\n134\t    \"model, distributed_executor_backend, attention_backend, test_suite, extra_env\",\n135\t    [\n136\t        (\"facebook/opt-125m\", \"ray\", \"\", \"L4\", {}),\n137\t        (\"facebook/opt-125m\", \"mp\", \"\", \"L4\", {}),\n138\t        (\"meta-llama/Llama-3.2-1B-Instruct\", \"ray\", \"\", \"L4\", {}),\n139\t        (\"meta-llama/Llama-3.2-1B-Instruct\", \"mp\", \"\", \"L4\", {}),\n140\t        (\"facebook/opt-125m\", \"ray\", \"\", \"A100\", {}),\n141\t        (\"facebook/opt-125m\", \"mp\", \"\", \"A100\", {}),\n142\t    ],\n143\t)\n144\t@pytest.mark.parametrize(\"enable_prompt_embeds\", [True, False])\n145\tdef test_models_distributed(\n146\t    monkeypatch: pytest.MonkeyPatch,\n147\t    hf_runner,\n148\t    vllm_runner,\n149\t    example_prompts,\n150\t    model: str,\n151\t    distributed_executor_backend: str,\n152\t    attention_backend: str,\n153\t    test_suite: str,\n154\t    extra_env: dict[str, str],\n155\t    enable_prompt_embeds: bool,\n156\t) -> None:\n157\t    if test_suite != TARGET_TEST_SUITE:\n158\t        pytest.skip(f\"Skip test for {test_suite}\")\n159\t\n160\t    with monkeypatch.context() as monkeypatch_context:\n161\t        if (\n162\t            model == \"meta-llama/Llama-3.2-1B-Instruct\"\n163\t            and distributed_executor_backend == \"ray\"\n164\t            and attention_backend == \"\"\n165\t            and test_suite == \"L4\"\n166\t            and enable_prompt_embeds\n167\t        ):  # noqa\n168\t            pytest.skip(\"enable_prompt_embeds does not work with ray compiled dag.\")\n169\t\n170\t        for k, v in extra_env.items():\n171\t            monkeypatch_context.setenv(k, v)\n172\t\n173\t        dtype = \"half\"\n174\t        max_tokens = 5\n175\t\n176\t        # NOTE: take care of the order. run vLLM first, and then run HF.\n177\t        # vLLM needs a fresh new process without cuda initialization.\n178\t        # if we run HF first, the cuda initialization will be done and it\n179\t        # will hurt multiprocessing backend with fork method\n180\t        # (the default method).\n181\t        attention_config = {\"backend\": attention_backend} if attention_backend else None\n182\t        with vllm_runner(\n183\t            model,\n184\t            dtype=dtype,\n185\t            tensor_parallel_size=2,\n186\t            distributed_executor_backend=distributed_executor_backend,\n187\t            enable_prompt_embeds=enable_prompt_embeds,\n188\t            gpu_memory_utilization=0.7,\n189\t            attention_config=attention_config,\n190\t        ) as vllm_model:\n191\t            if enable_prompt_embeds:\n192\t                with hf_runner(model, dtype=dtype) as hf_model:\n193\t                    with torch.no_grad():\n194\t                        prompt_embeds = hf_model.get_prompt_embeddings(example_prompts)\n195\t                    vllm_outputs = vllm_model.generate_greedy(prompt_embeds, max_tokens)\n196\t                    vllm_outputs = _fix_prompt_embed_outputs(\n197\t                        vllm_outputs, hf_model, example_prompts\n198\t                    )\n199\t                    hf_outputs = hf_model.generate_greedy(example_prompts, max_tokens)\n200\t            else:\n201\t                vllm_outputs = vllm_model.generate_greedy(example_prompts, max_tokens)\n202\t                with hf_runner(model, dtype=dtype) as hf_model:\n203\t                    hf_outputs = hf_model.generate_greedy(example_prompts, max_tokens)\n204\t\n205\t    check_outputs_equal(\n206\t        outputs_0_lst=hf_outputs,\n207\t        outputs_1_lst=vllm_outputs,\n208\t        name_0=\"hf\",\n209\t        name_1=\"vllm\",\n210\t    )\n211\t\n212\t\n213\tdef test_failed_model_execution(vllm_runner, monkeypatch) -> None:\n214\t    # Needed to mock an error in the same process\n215\t    monkeypatch.setenv(\"VLLM_ENABLE_V1_MULTIPROCESSING\", \"0\")\n216\t\n217\t    with vllm_runner(\"facebook/opt-125m\", enforce_eager=True) as vllm_model:\n218\t        if isinstance(vllm_model.llm.llm_engine, LLMEngine):\n219\t            v1_test_failed_model_execution(vllm_model)\n220\t\n221\t\n222\tdef v1_test_failed_model_execution(vllm_model):\n223\t    engine = vllm_model.llm.llm_engine\n224\t    mocked_execute_model = Mock(side_effect=RuntimeError(\"Mocked Critical Error\"))\n225\t    engine.engine_core.engine_core.model_executor.execute_model = mocked_execute_model\n226\t\n227\t    with pytest.raises(RuntimeError) as exc_info:\n228\t        prompts = [\n229\t            \"Hello, my name is\",\n230\t            \"The president of the United States is\",\n231\t            \"The capital of France is\",\n232\t            \"The future of AI is\",\n233\t        ]\n234\t        vllm_model.generate_greedy(prompts, 200, use_tqdm=False)\n235\t    assert isinstance(exc_info.value, RuntimeError)\n236\t    assert \"Mocked Critical Error\" in str(exc_info.value)\n237\t"}]},"parent_tool_use_id":"toolu_vrtx_01JVLZeSgRLA7Js8E4G1ZQCd","session_id":"a1879361-8ad3-49bc-ad0d-bf78fd163104","uuid":"ca69b691-41c8-4e3d-9186-b85bf35304a4","timestamp":"2026-07-08T18:26:31.741Z","subagent_type":"vllm-test-audit:audit-agent","task_description":"Audit vLLM basic_correctness tests"}
