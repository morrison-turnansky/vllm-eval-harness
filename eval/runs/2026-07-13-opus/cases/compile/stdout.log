{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01VBHAn3d1iZE58PiwoS2yJP","type":"tool_result","content":"1\t\"\"\"List test functions from PRs, directories, files, or file::function targets.\n2\t\n3\tDetects input type automatically. Always outputs DIR,FILE,FUNCTION CSV.\n4\t\n5\tFor PRs:\n6\t  - New test files: extracts added test function definitions from diff.\n7\t  - Modified test files: maps changed line numbers to enclosing test function.\n8\t\n9\tUsage:\n10\t    python list_tests.py https://github.com/vllm-project/vllm/pull/1234\n11\t    python list_tests.py 1234 --repo vllm-project/vllm\n12\t    python list_tests.py tests/compile/correctness_e2e/\n13\t    python list_tests.py tests/v1/e2e/spec_decode/test_spec_decode.py\n14\t    python list_tests.py tests/v1/e2e/spec_decode/test_spec_decode.py::test_mtp_correctness\n15\t\"\"\"\n16\t\n17\timport os\n18\timport re\n19\timport subprocess\n20\timport sys\n21\tfrom pathlib import Path\n22\t\n23\tTEST_FUNC_RE = re.compile(r\"(?:    )?(?:async )?def (test_\\w+)\")\n24\tADDED_FUNC_RE = re.compile(r\"\\+\\s*(?:async )?def (test_\\w+)\")\n25\t\n26\t\n27\tdef list_functions(file_path: str) -> list[tuple[str, str, str]]:\n28\t    \"\"\"List all test functions in a single test file.\n29\t\n30\t    Args:\n31\t        file_path: Path to a test_*.py file.\n32\t\n33\t    Returns:\n34\t        List of (directory, filename, function_name) tuples.\n35\t    \"\"\"\n36\t    results = []\n37\t    path = Path(file_path)\n38\t    if not path.is_file():\n39\t        return results\n40\t    for line in path.read_text().splitlines():\n41\t        match = TEST_FUNC_RE.match(line)\n42\t        if match:\n43\t            results.append((str(path.parent), path.name, match.group(1)))\n44\t    return results\n45\t\n46\t\n47\tdef list_from_directory(dir_path: str) -> list[tuple[str, str, str]]:\n48\t    \"\"\"List all test functions in all test_*.py files in a directory.\n49\t\n50\t    Args:\n51\t        dir_path: Path to a directory to search recursively.\n52\t\n53\t    Returns:\n54\t        List of (directory, filename, function_name) tuples.\n55\t    \"\"\"\n56\t    results = []\n57\t    for path in sorted(Path(dir_path).rglob(\"test_*.py\")):\n58\t        results.extend(list_functions(str(path)))\n59\t    return results\n60\t\n61\t\n62\tdef get_pr_diff(args: list[str]) -> str:\n63\t    \"\"\"Fetch PR diff via gh CLI.\n64\t\n65\t    Args:\n66\t        args: Arguments to pass to ``gh pr diff`` (PR URL/number, --repo, etc).\n67\t\n68\t    Returns:\n69\t        The unified diff as a string.\n70\t    \"\"\"\n71\t    result = subprocess.run(\n72\t        [\"gh\", \"pr\", \"diff\", *args],\n73\t        capture_output=True,\n74\t        text=True,\n75\t    )\n76\t    if result.returncode != 0:\n77\t        print(\"Failed to fetch PR diff\", file=sys.stderr)\n78\t        sys.exit(1)\n79\t    return result.stdout\n80\t\n81\t\n82\tdef _build_test_func_map(file_path: str) -> list[tuple[int, str]]:\n83\t    \"\"\"Build a mapping of line numbers to test function names.\n84\t\n85\t    Args:\n86\t        file_path: Path to a Python test file.\n87\t\n88\t    Returns:\n89\t        List of (line_number, function_name) tuples, ordered by line number.\n90\t    \"\"\"\n91\t    test_starts = []\n92\t    with open(file_path) as source_file:\n93\t        for line_num, line in enumerate(source_file, 1):\n94\t            match = TEST_FUNC_RE.match(line)\n95\t            if match:\n96\t                test_starts.append((line_num, match.group(1)))\n97\t    return test_starts\n98\t\n99\t\n100\tdef list_from_pr(args: list[str]) -> list[tuple[str, str, str]]:\n101\t    \"\"\"Extract changed/added test functions from a PR diff.\n102\t\n103\t    For new files, extracts ``+def test_`` lines from the diff. For modified\n104\t    files, maps changed line numbers to enclosing test functions by reading\n105\t    the local checkout.\n106\t\n107\t    Args:\n108\t        args: Arguments to pass to ``gh pr diff``.\n109\t\n110\t    Returns:\n111\t        Sorted list of (directory, filename, function_name) tuples.\n112\t    \"\"\"\n113\t    diff = get_pr_diff(args)\n114\t\n115\t    current_file: str | None = None\n116\t    current_line = 0\n117\t    prev_was_dev_null = False\n118\t\n119\t    new_funcs: dict[str, set[str]] = {}\n120\t    file_lines: dict[str, set[int]] = {}\n121\t    new_files: set[str] = set()\n122\t\n123\t    for line in diff.splitlines():\n124\t        if line.startswith(\"--- \"):\n125\t            prev_was_dev_null = line.startswith(\"--- /dev/null\")\n126\t        elif line.startswith(\"+++ b/\"):\n127\t            file_path = line[6:]\n128\t            if \"/test_\" in file_path and file_path.endswith(\".py\"):\n129\t                current_file = file_path\n130\t                if prev_was_dev_null:\n131\t                    new_files.add(file_path)\n132\t            else:\n133\t                current_file = None\n134\t        elif line.startswith(\"@@\"):\n135\t            hunk_match = re.match(r\"@@ -\\d+(?:,\\d+)? \\+(\\d+)\", line)\n136\t            if hunk_match:\n137\t                current_line = int(hunk_match.group(1))\n138\t        elif not current_file:\n139\t            pass\n140\t        elif line.startswith(\"+\"):\n141\t            func_match = ADDED_FUNC_RE.match(line)\n142\t            if func_match:\n143\t                new_funcs.setdefault(current_file, set()).add(func_match.group(1))\n144\t            file_lines.setdefault(current_file, set()).add(current_line)\n145\t            current_line += 1\n146\t        elif line.startswith(\"-\"):\n147\t            file_lines.setdefault(current_file, set()).add(current_line)\n148\t        else:\n149\t            current_line += 1\n150\t\n151\t    all_files = sorted(set(list(new_funcs.keys()) + list(file_lines.keys())))\n152\t    results: set[tuple[str, str, str]] = set()\n153\t\n154\t    for file_path in all_files:\n155\t        dir_name = os.path.dirname(file_path)\n156\t        base_name = os.path.basename(file_path)\n157\t\n158\t        if file_path in new_files:\n159\t            for func_name in new_funcs.get(file_path, set()):\n160\t                results.add((dir_name, base_name, func_name))\n161\t        else:\n162\t            if os.path.isfile(file_path):\n163\t                test_starts = _build_test_func_map(file_path)\n164\t                for changed_line in file_lines.get(file_path, set()):\n165\t                    for start_line, func_name in reversed(test_starts):\n166\t                        if start_line <= changed_line:\n167\t                            results.add((dir_name, base_name, func_name))\n168\t                            break\n169\t\n170\t            for func_name in new_funcs.get(file_path, set()):\n171\t                results.add((dir_name, base_name, func_name))\n172\t\n173\t    return sorted(results)\n174\t\n175\t\n176\tdef is_pr(arg: str) -> bool:\n177\t    \"\"\"Check if the argument looks like a PR URL or number.\n178\t\n179\t    Args:\n180\t        arg: Command-line argument to check.\n181\t\n182\t    Returns:\n183\t        True if the argument is a GitHub PR URL or a plain number.\n184\t    \"\"\"\n185\t    if re.match(r\"^https://github\\.com/.*/pull/\\d+\", arg):\n186\t        return True\n187\t    if re.match(r\"^\\d+$\", arg):\n188\t        return True\n189\t    return False\n190\t\n191\t\n192\tdef main() -> None:\n193\t    \"\"\"Entry point for CLI usage.\"\"\"\n194\t    if len(sys.argv) < 2:\n195\t        print(\n196\t            \"Usage: list_tests.py <pr-url|pr-number|directory|file|file::function> \"\n197\t            \"[--repo owner/repo]\",\n198\t            file=sys.stderr,\n199\t        )\n200\t        sys.exit(1)\n201\t\n202\t    target = sys.argv[1]\n203\t    results: list[tuple[str, str, str]] = []\n204\t\n205\t    if is_pr(target):\n206\t        results = list_from_pr(sys.argv[1:])\n207\t    elif \"::\" in target:\n208\t        file_path, func_name = target.split(\"::\", 1)\n209\t        results = [(os.path.dirname(file_path), os.path.basename(file_path), func_name)]\n210\t    elif os.path.isfile(target) and \"/test_\" in target:\n211\t        results = list_functions(target)\n212\t    elif os.path.isdir(target):\n213\t        results = list_from_directory(target)\n214\t\n215\t    for dir_name, base_name, func_name in results:\n216\t        print(f\"{dir_name},{base_name},{func_name}\")\n217\t\n218\t\n219\tif __name__ == \"__main__\":\n220\t    main()\n221\t"}]},"parent_tool_use_id":null,"session_id":"603f2b8b-1633-4397-a4a3-f9f63565a548","uuid":"3d3f1d15-5a24-4821-a947-b59c3145c815","timestamp":"2026-07-13T16:45:03.426Z","tool_use_result":{"type":"text","file":{"filePath":"/home/devuser/projects/ai-marketplace/vllm-test-audit/scripts/list_tests.py","content":"\"\"\"List test functions from PRs, directories, files, or file::function targets.\n\nDetects input type automatically. Always outputs DIR,FILE,FUNCTION CSV.\n\nFor PRs:\n  - New test files: extracts added test function definitions from diff.\n  - Modified test files: maps changed line numbers to enclosing test function.\n\nUsage:\n    python list_tests.py https://github.com/vllm-project/vllm/pull/1234\n    python list_tests.py 1234 --repo vllm-project/vllm\n    python list_tests.py tests/compile/correctness_e2e/\n    python list_tests.py tests/v1/e2e/spec_decode/test_spec_decode.py\n    python list_tests.py tests/v1/e2e/spec_decode/test_spec_decode.py::test_mtp_correctness\n\"\"\"\n\nimport os\nimport re\nimport subprocess\nimport sys\nfrom pathlib import Path\n\nTEST_FUNC_RE = re.compile(r\"(?:    )?(?:async )?def (test_\\w+)\")\nADDED_FUNC_RE = re.compile(r\"\\+\\s*(?:async )?def (test_\\w+)\")\n\n\ndef list_functions(file_path: str) -> list[tuple[str, str, str]]:\n    \"\"\"List all test functions in a single test file.\n\n    Args:\n        file_path: Path to a test_*.py file.\n\n    Returns:\n        List of (directory, filename, function_name) tuples.\n    \"\"\"\n    results = []\n    path = Path(file_path)\n    if not path.is_file():\n        return results\n    for line in path.read_text().splitlines():\n        match = TEST_FUNC_RE.match(line)\n        if match:\n            results.append((str(path.parent), path.name, match.group(1)))\n    return results\n\n\ndef list_from_directory(dir_path: str) -> list[tuple[str, str, str]]:\n    \"\"\"List all test functions in all test_*.py files in a directory.\n\n    Args:\n        dir_path: Path to a directory to search recursively.\n\n    Returns:\n        List of (directory, filename, function_name) tuples.\n    \"\"\"\n    results = []\n    for path in sorted(Path(dir_path).rglob(\"test_*.py\")):\n        results.extend(list_functions(str(path)))\n    return results\n\n\ndef get_pr_diff(args: list[str]) -> str:\n    \"\"\"Fetch PR diff via gh CLI.\n\n    Args:\n        args: Arguments to pass to ``gh pr diff`` (PR URL/number, --repo, etc).\n\n    Returns:\n        The unified diff as a string.\n    \"\"\"\n    result = subprocess.run(\n        [\"gh\", \"pr\", \"diff\", *args],\n        capture_output=True,\n        text=True,\n    )\n    if result.returncode != 0:\n        print(\"Failed to fetch PR diff\", file=sys.stderr)\n        sys.exit(1)\n    return result.stdout\n\n\ndef _build_test_func_map(file_path: str) -> list[tuple[int, str]]:\n    \"\"\"Build a mapping of line numbers to test function names.\n\n    Args:\n        file_path: Path to a Python test file.\n\n    Returns:\n        List of (line_number, function_name) tuples, ordered by line number.\n    \"\"\"\n    test_starts = []\n    with open(file_path) as source_file:\n        for line_num, line in enumerate(source_file, 1):\n            match = TEST_FUNC_RE.match(line)\n            if match:\n                test_starts.append((line_num, match.group(1)))\n    return test_starts\n\n\ndef list_from_pr(args: list[str]) -> list[tuple[str, str, str]]:\n    \"\"\"Extract changed/added test functions from a PR diff.\n\n    For new files, extracts ``+def test_`` lines from the diff. For modified\n    files, maps changed line numbers to enclosing test functions by reading\n    the local checkout.\n\n    Args:\n        args: Arguments to pass to ``gh pr diff``.\n\n    Returns:\n        Sorted list of (directory, filename, function_name) tuples.\n    \"\"\"\n    diff = get_pr_diff(args)\n\n    current_file: str | None = None\n    current_line = 0\n    prev_was_dev_null = False\n\n    new_funcs: dict[str, set[str]] = {}\n    file_lines: dict[str, set[int]] = {}\n    new_files: set[str] = set()\n\n    for line in diff.splitlines():\n        if line.startswith(\"--- \"):\n            prev_was_dev_null = line.startswith(\"--- /dev/null\")\n        elif line.startswith(\"+++ b/\"):\n            file_path = line[6:]\n            if \"/test_\" in file_path and file_path.endswith(\".py\"):\n                current_file = file_path\n                if prev_was_dev_null:\n                    new_files.add(file_path)\n            else:\n                current_file = None\n        elif line.startswith(\"@@\"):\n            hunk_match = re.match(r\"@@ -\\d+(?:,\\d+)? \\+(\\d+)\", line)\n            if hunk_match:\n                current_line = int(hunk_match.group(1))\n        elif not current_file:\n            pass\n        elif line.startswith(\"+\"):\n            func_match = ADDED_FUNC_RE.match(line)\n            if func_match:\n                new_funcs.setdefault(current_file, set()).add(func_match.group(1))\n            file_lines.setdefault(current_file, set()).add(current_line)\n            current_line += 1\n        elif line.startswith(\"-\"):\n            file_lines.setdefault(current_file, set()).add(current_line)\n        else:\n            current_line += 1\n\n    all_files = sorted(set(list(new_funcs.keys()) + list(file_lines.keys())))\n    results: set[tuple[str, str, str]] = set()\n\n    for file_path in all_files:\n        dir_name = os.path.dirname(file_path)\n        base_name = os.path.basename(file_path)\n\n        if file_path in new_files:\n            for func_name in new_funcs.get(file_path, set()):\n                results.add((dir_name, base_name, func_name))\n        else:\n            if os.path.isfile(file_path):\n                test_starts = _build_test_func_map(file_path)\n                for changed_line in file_lines.get(file_path, set()):\n                    for start_line, func_name in reversed(test_starts):\n                        if start_line <= changed_line:\n                            results.add((dir_name, base_name, func_name))\n                            break\n\n            for func_name in new_funcs.get(file_path, set()):\n                results.add((dir_name, base_name, func_name))\n\n    return sorted(results)\n\n\ndef is_pr(arg: str) -> bool:\n    \"\"\"Check if the argument looks like a PR URL or number.\n\n    Args:\n        arg: Command-line argument to check.\n\n    Returns:\n        True if the argument is a GitHub PR URL or a plain number.\n    \"\"\"\n    if re.match(r\"^https://github\\.com/.*/pull/\\d+\", arg):\n        return True\n    if re.match(r\"^\\d+$\", arg):\n        return True\n    return False\n\n\ndef main() -> None:\n    \"\"\"Entry point for CLI usage.\"\"\"\n    if len(sys.argv) < 2:\n        print(\n            \"Usage: list_tests.py <pr-url|pr-number|directory|file|file::function> \"\n            \"[--repo owner/repo]\",\n            file=sys.stderr,\n        )\n        sys.exit(1)\n\n    target = sys.argv[1]\n    results: list[tuple[str, str, str]] = []\n\n    if is_pr(target):\n        results = list_from_pr(sys.argv[1:])\n    elif \"::\" in target:\n        file_path, func_name = target.split(\"::\", 1)\n        results = [(os.path.dirname(file_path), os.path.basename(file_path), func_name)]\n    elif os.path.isfile(target) and \"/test_\" in target:\n        results = list_functions(target)\n    elif os.path.isdir(target):\n        results = list_from_directory(target)\n\n    for dir_name, base_name, func_name in results:\n        print(f\"{dir_name},{base_name},{func_name}\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":221,"startLine":1,"totalLines":221}}}
