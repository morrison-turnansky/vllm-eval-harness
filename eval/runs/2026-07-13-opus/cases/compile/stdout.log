{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01YPcwDP3qruQVMXLNHR7jdo","type":"tool_result","content":"1\t# SPDX-License-Identifier: Apache-2.0\n2\t# SPDX-FileCopyrightText: Copyright contributors to the vLLM project\n3\t\"\"\"\n4\tWARNING: This test runs in both single-node (4 GPUs) and multi-node\n5\t (2 node with 2 GPUs each) modes. If the test only uses 2 GPUs, it is\n6\t important to set the distributed backend to \"mp\" to avoid Ray scheduling\n7\t all workers in a node other than the head node, which can cause the test\n8\t to fail.\n9\t\"\"\"\n10\t\n11\timport json\n12\timport os\n13\tfrom dataclasses import dataclass\n14\tfrom typing import Literal, NamedTuple\n15\t\n16\timport pytest\n17\t\n18\tfrom vllm.config.compilation import CompilationMode\n19\tfrom vllm.config.model import RunnerOption\n20\tfrom vllm.logger import init_logger\n21\tfrom vllm.platforms import current_platform\n22\tfrom vllm.utils.torch_utils import is_torch_equal_or_newer\n23\t\n24\tfrom ...models.registry import HF_EXAMPLE_MODELS, _HfExamplesInfo\n25\tfrom ...utils import compare_two_settings, create_new_process_for_each_test\n26\t\n27\tlogger = init_logger(\"test_sequence_parallel\")\n28\t\n29\tVLLM_MULTI_NODE = os.getenv(\"VLLM_MULTI_NODE\", \"0\") == \"1\"\n30\tNVFP4_MODEL_ID = \"nvidia/Llama-3.1-8B-Instruct-NVFP4\"\n31\tNVFP4_MODEL_INFO = _HfExamplesInfo(NVFP4_MODEL_ID)\n32\t\n33\t\n34\tclass ParallelSetup(NamedTuple):\n35\t    tp_size: int\n36\t    pp_size: int\n37\t    fuse_norm_quant: bool\n38\t    fuse_act_quant: bool\n39\t    eager_mode: bool\n40\t    chunked_prefill: bool\n41\t\n42\t\n43\tclass SPTestOptions(NamedTuple):\n44\t    multi_node_only: bool\n45\t    load_format: str | None = None\n46\t    model_info: _HfExamplesInfo | None = None\n47\t\n48\t\n49\t@dataclass\n50\tclass SPTestSettings:\n51\t    parallel_setups: list[ParallelSetup]\n52\t    distributed_backends: list[str]\n53\t    runner: RunnerOption\n54\t    test_options: SPTestOptions\n55\t\n56\t    @staticmethod\n57\t    def detailed(\n58\t        *,\n59\t        tp_base: int = 2,\n60\t        pp_base: int = 1,\n61\t        multi_node_only: bool = False,\n62\t        runner: RunnerOption = \"auto\",\n63\t        load_format: str | None = None,\n64\t    ):\n65\t        parallel_setups = []\n66\t        for eager_mode_val in [False, True]:\n67\t            for pp_multiplier in [1, 2]:\n68\t                for chunked_prefill_val in [False, True]:\n69\t                    parallel_setups.append(\n70\t                        ParallelSetup(\n71\t                            tp_size=tp_base,\n72\t                            pp_size=pp_multiplier * pp_base,\n73\t                            fuse_norm_quant=False,\n74\t                            fuse_act_quant=False,\n75\t                            eager_mode=eager_mode_val,\n76\t                            chunked_prefill=chunked_prefill_val,\n77\t                        )\n78\t                    )\n79\t        return SPTestSettings(\n80\t            parallel_setups=parallel_setups,\n81\t            distributed_backends=[\"mp\", \"ray\"],\n82\t            runner=runner,\n83\t            test_options=SPTestOptions(\n84\t                multi_node_only=multi_node_only, load_format=load_format\n85\t            ),\n86\t        )\n87\t\n88\t    @staticmethod\n89\t    def fast(\n90\t        *,\n91\t        tp_base: int = 2,\n92\t        pp_base: int = 1,\n93\t        runner: RunnerOption = \"auto\",\n94\t        multi_node_only: bool = False,\n95\t        load_format: str | None = None,\n96\t    ):\n97\t        parallel_setups = []\n98\t        for eager_mode_val in [False, True]:\n99\t            for pp_multiplier in [1, 2]:\n100\t                for chunked_prefill_val in [False, True]:\n101\t                    parallel_setups.append(\n102\t                        ParallelSetup(\n103\t                            tp_size=tp_base,\n104\t                            pp_size=pp_multiplier * pp_base,\n105\t                            fuse_norm_quant=False,\n106\t                            fuse_act_quant=False,\n107\t                            eager_mode=eager_mode_val,\n108\t                            chunked_prefill=chunked_prefill_val,\n109\t                        )\n110\t                    )\n111\t        return SPTestSettings(\n112\t            parallel_setups=parallel_setups,\n113\t            distributed_backends=[\"mp\", \"ray\"],\n114\t            runner=runner,\n115\t            test_options=SPTestOptions(\n116\t                multi_node_only=multi_node_only, load_format=load_format\n117\t            ),\n118\t        )\n119\t\n120\t    @staticmethod\n121\t    def fp8_quant(\n122\t        *,\n123\t        tp_base: int = 2,\n124\t        pp_base: int = 1,\n125\t        runner: RunnerOption = \"auto\",\n126\t        multi_node_only: bool = False,\n127\t        load_format: str | None = None,\n128\t    ):\n129\t        parallel_setups = []\n130\t        for fusion_val in [False, True]:\n131\t            parallel_setups.append(\n132\t                ParallelSetup(\n133\t                    tp_size=tp_base,\n134\t                    pp_size=pp_base,\n135\t                    fuse_norm_quant=fusion_val,\n136\t                    fuse_act_quant=fusion_val,\n137\t                    eager_mode=True,\n138\t                    chunked_prefill=False,\n139\t                )\n140\t            )\n141\t        return SPTestSettings(\n142\t            parallel_setups=parallel_setups,\n143\t            distributed_backends=[\"mp\", \"ray\"],\n144\t            runner=runner,\n145\t            test_options=SPTestOptions(\n146\t                multi_node_only=multi_node_only, load_format=load_format\n147\t            ),\n148\t        )\n149\t\n150\t    def iter_params(self, model_id: str):\n151\t        opts = self.test_options\n152\t\n153\t        for parallel_setup in self.parallel_setups:\n154\t            for backend in self.distributed_backends:\n155\t                yield (\n156\t                    model_id,\n157\t                    parallel_setup,\n158\t                    backend,\n159\t                    self.runner,\n160\t                    opts,\n161\t                )\n162\t\n163\t\n164\tdef _compare_sp(\n165\t    model_id: str,\n166\t    parallel_setup: ParallelSetup,\n167\t    distributed_backend: str,\n168\t    runner: RunnerOption,\n169\t    test_options: SPTestOptions,\n170\t    num_gpus_available: int,\n171\t    use_inductor_graph_partition: bool,\n172\t    fuse_gemm_comms: bool,\n173\t    enable_prompt_embeds: bool,\n174\t    *,\n175\t    method: Literal[\"generate\", \"encode\"],\n176\t    is_multimodal: bool,\n177\t    dtype: str = \"float16\",\n178\t):\n179\t    (\n180\t        tp_size,\n181\t        pp_size,\n182\t        fuse_norm_quant,\n183\t        fuse_act_quant,\n184\t        eager_mode,\n185\t        chunked_prefill,\n186\t    ) = parallel_setup\n187\t\n188\t    multi_node_only = test_options.multi_node_only\n189\t    load_format = test_options.load_format\n190\t\n191\t    model_info = test_options.model_info or HF_EXAMPLE_MODELS.find_hf_info(model_id)\n192\t    model_info.check_transformers_version(on_fail=\"skip\")\n193\t\n194\t    trust_remote_code = model_info.trust_remote_code\n195\t    tokenizer_mode = model_info.tokenizer_mode\n196\t    hf_overrides = dict(model_info.hf_overrides)\n197\t    require_embed_inputs = model_info.require_embed_inputs\n198\t\n199\t    if load_format == \"dummy\":\n200\t        # Avoid OOM\n201\t        text_overrides = {\n202\t            \"num_hidden_layers\": 4,\n203\t            \"hidden_size\": 512,\n204\t            \"intermediate_size\": 800,\n205\t            \"num_attention_heads\": 4,\n206\t            \"num_key_value_heads\": 1,\n207\t        }\n208\t\n209\t        if is_multimodal:\n210\t            hf_overrides.update({\"text_config\": text_overrides})\n211\t        else:\n212\t            hf_overrides.update(text_overrides)\n213\t    else:\n214\t        model_info.check_available_online(on_fail=\"skip\")\n215\t\n216\t    if num_gpus_available < tp_size * pp_size:\n217\t        pytest.skip(f\"Need at least {tp_size} x {pp_size} GPUs\")\n218\t    if VLLM_MULTI_NODE and distributed_backend == \"mp\":\n219\t        pytest.skip(\n220\t            \"Skipping multi-node pipeline parallel test for \"\n221\t            \"multiprocessing distributed backend\"\n222\t        )\n223\t    if multi_node_only and not VLLM_MULTI_NODE:\n224\t        pytest.skip(\"Not in multi-node setting\")\n225\t\n226\t    common_args = [\n227\t        # use half precision for speed and memory savings in CI environment\n228\t        \"--dtype\",\n229\t        dtype,\n230\t        \"--max-model-len\",\n231\t        \"2048\",\n232\t        \"--max-num-seqs\",\n233\t        \"8\",\n234\t    ]\n235\t    if chunked_prefill:\n236\t        common_args.append(\"--enable-chunked-prefill\")\n237\t    if eager_mode:\n238\t        common_args.append(\"-cc.cudagraph_mode=none\")\n239\t    if runner != \"auto\":\n240\t        common_args.extend([\"--runner\", runner])\n241\t    if trust_remote_code:\n242\t        common_args.append(\"--trust-remote-code\")\n243\t    if tokenizer_mode:\n244\t        common_args.extend([\"--tokenizer-mode\", tokenizer_mode])\n245\t    if load_format:\n246\t        common_args.extend([\"--load-format\", load_format])\n247\t    if hf_overrides:\n248\t        common_args.extend([\"--hf-overrides\", json.dumps(hf_overrides)])\n249\t    if require_embed_inputs:\n250\t        common_args.extend(\n251\t            [\n252\t                \"--skip-tokenizer-init\",\n253\t                \"--enable-prompt-embeds\",\n254\t                \"--enable-mm-embeds\",\n255\t            ]\n256\t        )\n257\t    elif enable_prompt_embeds:\n258\t        common_args.append(\"--enable-prompt-embeds\")\n259\t\n260\t    compilation_config = {\n261\t        \"mode\": CompilationMode.VLLM_COMPILE,\n262\t        \"compile_sizes\": [4, 8],\n263\t        \"pass_config\": {\n264\t            \"enable_sp\": True,\n265\t            \"fuse_gemm_comms\": fuse_gemm_comms,\n266\t            \"fuse_norm_quant\": fuse_norm_quant,\n267\t            \"fuse_act_quant\": fuse_act_quant,\n268\t            \"fuse_allreduce_rms\": False,\n269\t            \"eliminate_noops\": True,\n270\t            \"sp_min_token_num\": 0,\n271\t        },\n272\t        \"use_inductor_graph_partition\": use_inductor_graph_partition,\n273\t    }\n274\t    if not use_inductor_graph_partition:\n275\t        compilation_config[\"splitting_ops\"] = []\n276\t\n277\t    tp_sp_args = [\n278\t        *common_args,\n279\t        \"--tensor-parallel-size\",\n280\t        str(tp_size),\n281\t        \"--pipeline-parallel-size\",\n282\t        str(pp_size),\n283\t        \"--distributed-executor-backend\",\n284\t        distributed_backend,\n285\t        \"--compilation_config\",\n286\t        json.dumps(compilation_config),\n287\t    ]\n288\t\n289\t    tp_args = [\n290\t        *common_args,\n291\t        \"--tensor-parallel-size\",\n292\t        str(tp_size),\n293\t        \"--distributed-executor-backend\",\n294\t        \"mp\",\n295\t    ]\n296\t\n297\t    compare_two_settings(\n298\t        model_id,\n299\t        tp_sp_args,\n300\t        tp_args,\n301\t        method=method,\n302\t        force_v1_runner=True,\n303\t    )\n304\t\n305\t\n306\tSP_TEXT_GENERATION_MODELS = {\n307\t    # [Decoder-only]\n308\t    \"hmellor/tiny-random-LlamaForCausalLM\": SPTestSettings.fast(),\n309\t    \"RedHatAI/Meta-Llama-3.1-8B-Instruct-FP8\": SPTestSettings.fp8_quant(),\n310\t}\n311\t\n312\tSP_TEST_MODELS = [\n313\t    # TODO support other models\n314\t    # [LANGUAGE GENERATION]\n315\t    \"hmellor/tiny-random-LlamaForCausalLM\",\n316\t    \"RedHatAI/Meta-Llama-3.1-8B-Instruct-FP8\",\n317\t]\n318\t\n319\t\n320\t@pytest.mark.parametrize(\n321\t    (\n322\t        \"model_id\",\n323\t        \"parallel_setup\",\n324\t        \"distributed_backend\",\n325\t        \"runner\",\n326\t        \"test_options\",\n327\t    ),\n328\t    [\n329\t        params\n330\t        for model_id, settings in SP_TEXT_GENERATION_MODELS.items()\n331\t        for params in settings.iter_params(model_id)\n332\t        if model_id in SP_TEST_MODELS\n333\t    ],\n334\t)\n335\t@pytest.mark.parametrize(\"use_inductor_graph_partition\", [True, False])\n336\t@pytest.mark.parametrize(\"fuse_gemm_comms\", [False])  # TODO: enable async TP\n337\t@create_new_process_for_each_test()\n338\tdef test_tp_sp_generation(\n339\t    model_id: str,\n340\t    parallel_setup: ParallelSetup,\n341\t    distributed_backend: str,\n342\t    runner: RunnerOption,\n343\t    test_options: SPTestOptions,\n344\t    num_gpus_available,\n345\t    use_inductor_graph_partition: bool,\n346\t    fuse_gemm_comms: bool,\n347\t):\n348\t    if use_inductor_graph_partition and not is_torch_equal_or_newer(\"2.9.0.dev\"):\n349\t        pytest.skip(\"inductor graph partition is only available in PyTorch 2.9+\")\n350\t\n351\t    # Skip FP8 SP-only test on sm89 (compute capability 8.9)\n352\t    if (\n353\t        \"fp8\" in model_id.lower()\n354\t        and current_platform.get_device_capability() < (9, 0)\n355\t        and (not fuse_gemm_comms)\n356\t    ):\n357\t        pytest.skip(\"FP8 reduction support begins with sm90 capable devices.\")\n358\t\n359\t    _compare_sp(\n360\t        model_id,\n361\t        parallel_setup,\n362\t        distributed_backend,\n363\t        runner,\n364\t        test_options,\n365\t        num_gpus_available,\n366\t        use_inductor_graph_partition,\n367\t        fuse_gemm_comms=fuse_gemm_comms,\n368\t        enable_prompt_embeds=False,\n369\t        method=\"generate\",\n370\t        is_multimodal=False,\n371\t    )\n372\t\n373\t\n374\t# Focused regression test for the SP + prompt_embeds graph-rewrite path.\n375\t# Covers pp_size=1 (SP only) and pp_size=2 (SP + PP); kept small on purpose so\n376\t# we don't double the matrix of `test_tp_sp_generation` above.\n377\tSP_PROMPT_EMBEDS_PARALLEL_SETUPS = [\n378\t    ParallelSetup(\n379\t        tp_size=2,\n380\t        pp_size=pp_size,\n381\t        fuse_norm_quant=False,\n382\t        fuse_act_quant=False,\n383\t        eager_mode=False,\n384\t        chunked_prefill=False,\n385\t    )\n386\t    for pp_size in [1, 2]\n387\t]\n388\t\n389\t\n390\t@pytest.mark.parametrize(\"parallel_setup\", SP_PROMPT_EMBEDS_PARALLEL_SETUPS)\n391\t@pytest.mark.parametrize(\"use_inductor_graph_partition\", [True, False])\n392\t@create_new_process_for_each_test()\n393\tdef test_tp_sp_generation_prompt_embeds(\n394\t    parallel_setup: ParallelSetup,\n395\t    num_gpus_available,\n396\t    use_inductor_graph_partition: bool,\n397\t):\n398\t    if use_inductor_graph_partition and not is_torch_equal_or_newer(\"2.9.0.dev\"):\n399\t        pytest.skip(\"inductor graph partition is only available in PyTorch 2.9+\")\n400\t\n401\t    _compare_sp(\n402\t        \"hmellor/tiny-random-LlamaForCausalLM\",\n403\t        parallel_setup,\n404\t        distributed_backend=\"mp\",\n405\t        runner=\"auto\",\n406\t        test_options=SPTestOptions(multi_node_only=False, load_format=None),\n407\t        num_gpus_available=num_gpus_available,\n408\t        use_inductor_graph_partition=use_inductor_graph_partition,\n409\t        fuse_gemm_comms=False,\n410\t        enable_prompt_embeds=True,\n411\t        method=\"generate\",\n412\t        is_multimodal=False,\n413\t    )\n414\t\n415\t\n416\t@create_new_process_for_each_test()\n417\tdef test_tp_sp_nvfp4_generation(num_gpus_available: int):\n418\t    if (\n419\t        not current_platform.is_cuda()\n420\t        or not current_platform.is_device_capability_family(100)\n421\t    ):\n422\t        pytest.skip(\"NVFP4 requires Blackwell\")\n423\t\n424\t    _compare_sp(\n425\t        NVFP4_MODEL_ID,\n426\t        ParallelSetup(\n427\t            tp_size=2,\n428\t            pp_size=1,\n429\t            fuse_norm_quant=True,\n430\t            fuse_act_quant=True,\n431\t            eager_mode=True,\n432\t            chunked_prefill=False,\n433\t        ),\n434\t        \"mp\",\n435\t        \"auto\",\n436\t        SPTestOptions(\n437\t            multi_node_only=False,\n438\t            load_format=\"dummy\",\n439\t            model_info=NVFP4_MODEL_INFO,\n440\t        ),\n441\t        num_gpus_available,\n442\t        use_inductor_graph_partition=False,\n443\t        fuse_gemm_comms=False,\n444\t        enable_prompt_embeds=False,\n445\t        method=\"generate\",\n446\t        is_multimodal=False,\n447\t        dtype=\"bfloat16\",\n448\t    )\n449\t"}]},"parent_tool_use_id":null,"session_id":"603f2b8b-1633-4397-a4a3-f9f63565a548","uuid":"05cc4b8d-84a5-438f-82b1-f859708f3003","timestamp":"2026-07-13T16:45:19.315Z","tool_use_result":{"type":"text","file":{"filePath":"/home/devuser/projects/vllm/tests/compile/correctness_e2e/test_sequence_parallel.py","content":"# SPDX-License-Identifier: Apache-2.0\n# SPDX-FileCopyrightText: Copyright contributors to the vLLM project\n\"\"\"\nWARNING: This test runs in both single-node (4 GPUs) and multi-node\n (2 node with 2 GPUs each) modes. If the test only uses 2 GPUs, it is\n important to set the distributed backend to \"mp\" to avoid Ray scheduling\n all workers in a node other than the head node, which can cause the test\n to fail.\n\"\"\"\n\nimport json\nimport os\nfrom dataclasses import dataclass\nfrom typing import Literal, NamedTuple\n\nimport pytest\n\nfrom vllm.config.compilation import CompilationMode\nfrom vllm.config.model import RunnerOption\nfrom vllm.logger import init_logger\nfrom vllm.platforms import current_platform\nfrom vllm.utils.torch_utils import is_torch_equal_or_newer\n\nfrom ...models.registry import HF_EXAMPLE_MODELS, _HfExamplesInfo\nfrom ...utils import compare_two_settings, create_new_process_for_each_test\n\nlogger = init_logger(\"test_sequence_parallel\")\n\nVLLM_MULTI_NODE = os.getenv(\"VLLM_MULTI_NODE\", \"0\") == \"1\"\nNVFP4_MODEL_ID = \"nvidia/Llama-3.1-8B-Instruct-NVFP4\"\nNVFP4_MODEL_INFO = _HfExamplesInfo(NVFP4_MODEL_ID)\n\n\nclass ParallelSetup(NamedTuple):\n    tp_size: int\n    pp_size: int\n    fuse_norm_quant: bool\n    fuse_act_quant: bool\n    eager_mode: bool\n    chunked_prefill: bool\n\n\nclass SPTestOptions(NamedTuple):\n    multi_node_only: bool\n    load_format: str | None = None\n    model_info: _HfExamplesInfo | None = None\n\n\n@dataclass\nclass SPTestSettings:\n    parallel_setups: list[ParallelSetup]\n    distributed_backends: list[str]\n    runner: RunnerOption\n    test_options: SPTestOptions\n\n    @staticmethod\n    def detailed(\n        *,\n        tp_base: int = 2,\n        pp_base: int = 1,\n        multi_node_only: bool = False,\n        runner: RunnerOption = \"auto\",\n        load_format: str | None = None,\n    ):\n        parallel_setups = []\n        for eager_mode_val in [False, True]:\n            for pp_multiplier in [1, 2]:\n                for chunked_prefill_val in [False, True]:\n                    parallel_setups.append(\n                        ParallelSetup(\n                            tp_size=tp_base,\n                            pp_size=pp_multiplier * pp_base,\n                            fuse_norm_quant=False,\n                            fuse_act_quant=False,\n                            eager_mode=eager_mode_val,\n                            chunked_prefill=chunked_prefill_val,\n                        )\n                    )\n        return SPTestSettings(\n            parallel_setups=parallel_setups,\n            distributed_backends=[\"mp\", \"ray\"],\n            runner=runner,\n            test_options=SPTestOptions(\n                multi_node_only=multi_node_only, load_format=load_format\n            ),\n        )\n\n    @staticmethod\n    def fast(\n        *,\n        tp_base: int = 2,\n        pp_base: int = 1,\n        runner: RunnerOption = \"auto\",\n        multi_node_only: bool = False,\n        load_format: str | None = None,\n    ):\n        parallel_setups = []\n        for eager_mode_val in [False, True]:\n            for pp_multiplier in [1, 2]:\n                for chunked_prefill_val in [False, True]:\n                    parallel_setups.append(\n                        ParallelSetup(\n                            tp_size=tp_base,\n                            pp_size=pp_multiplier * pp_base,\n                            fuse_norm_quant=False,\n                            fuse_act_quant=False,\n                            eager_mode=eager_mode_val,\n                            chunked_prefill=chunked_prefill_val,\n                        )\n                    )\n        return SPTestSettings(\n            parallel_setups=parallel_setups,\n            distributed_backends=[\"mp\", \"ray\"],\n            runner=runner,\n            test_options=SPTestOptions(\n                multi_node_only=multi_node_only, load_format=load_format\n            ),\n        )\n\n    @staticmethod\n    def fp8_quant(\n        *,\n        tp_base: int = 2,\n        pp_base: int = 1,\n        runner: RunnerOption = \"auto\",\n        multi_node_only: bool = False,\n        load_format: str | None = None,\n    ):\n        parallel_setups = []\n        for fusion_val in [False, True]:\n            parallel_setups.append(\n                ParallelSetup(\n                    tp_size=tp_base,\n                    pp_size=pp_base,\n                    fuse_norm_quant=fusion_val,\n                    fuse_act_quant=fusion_val,\n                    eager_mode=True,\n                    chunked_prefill=False,\n                )\n            )\n        return SPTestSettings(\n            parallel_setups=parallel_setups,\n            distributed_backends=[\"mp\", \"ray\"],\n            runner=runner,\n            test_options=SPTestOptions(\n                multi_node_only=multi_node_only, load_format=load_format\n            ),\n        )\n\n    def iter_params(self, model_id: str):\n        opts = self.test_options\n\n        for parallel_setup in self.parallel_setups:\n            for backend in self.distributed_backends:\n                yield (\n                    model_id,\n                    parallel_setup,\n                    backend,\n                    self.runner,\n                    opts,\n                )\n\n\ndef _compare_sp(\n    model_id: str,\n    parallel_setup: ParallelSetup,\n    distributed_backend: str,\n    runner: RunnerOption,\n    test_options: SPTestOptions,\n    num_gpus_available: int,\n    use_inductor_graph_partition: bool,\n    fuse_gemm_comms: bool,\n    enable_prompt_embeds: bool,\n    *,\n    method: Literal[\"generate\", \"encode\"],\n    is_multimodal: bool,\n    dtype: str = \"float16\",\n):\n    (\n        tp_size,\n        pp_size,\n        fuse_norm_quant,\n        fuse_act_quant,\n        eager_mode,\n        chunked_prefill,\n    ) = parallel_setup\n\n    multi_node_only = test_options.multi_node_only\n    load_format = test_options.load_format\n\n    model_info = test_options.model_info or HF_EXAMPLE_MODELS.find_hf_info(model_id)\n    model_info.check_transformers_version(on_fail=\"skip\")\n\n    trust_remote_code = model_info.trust_remote_code\n    tokenizer_mode = model_info.tokenizer_mode\n    hf_overrides = dict(model_info.hf_overrides)\n    require_embed_inputs = model_info.require_embed_inputs\n\n    if load_format == \"dummy\":\n        # Avoid OOM\n        text_overrides = {\n            \"num_hidden_layers\": 4,\n            \"hidden_size\": 512,\n            \"intermediate_size\": 800,\n            \"num_attention_heads\": 4,\n            \"num_key_value_heads\": 1,\n        }\n\n        if is_multimodal:\n            hf_overrides.update({\"text_config\": text_overrides})\n        else:\n            hf_overrides.update(text_overrides)\n    else:\n        model_info.check_available_online(on_fail=\"skip\")\n\n    if num_gpus_available < tp_size * pp_size:\n        pytest.skip(f\"Need at least {tp_size} x {pp_size} GPUs\")\n    if VLLM_MULTI_NODE and distributed_backend == \"mp\":\n        pytest.skip(\n            \"Skipping multi-node pipeline parallel test for \"\n            \"multiprocessing distributed backend\"\n        )\n    if multi_node_only and not VLLM_MULTI_NODE:\n        pytest.skip(\"Not in multi-node setting\")\n\n    common_args = [\n        # use half precision for speed and memory savings in CI environment\n        \"--dtype\",\n        dtype,\n        \"--max-model-len\",\n        \"2048\",\n        \"--max-num-seqs\",\n        \"8\",\n    ]\n    if chunked_prefill:\n        common_args.append(\"--enable-chunked-prefill\")\n    if eager_mode:\n        common_args.append(\"-cc.cudagraph_mode=none\")\n    if runner != \"auto\":\n        common_args.extend([\"--runner\", runner])\n    if trust_remote_code:\n        common_args.append(\"--trust-remote-code\")\n    if tokenizer_mode:\n        common_args.extend([\"--tokenizer-mode\", tokenizer_mode])\n    if load_format:\n        common_args.extend([\"--load-format\", load_format])\n    if hf_overrides:\n        common_args.extend([\"--hf-overrides\", json.dumps(hf_overrides)])\n    if require_embed_inputs:\n        common_args.extend(\n            [\n                \"--skip-tokenizer-init\",\n                \"--enable-prompt-embeds\",\n                \"--enable-mm-embeds\",\n            ]\n        )\n    elif enable_prompt_embeds:\n        common_args.append(\"--enable-prompt-embeds\")\n\n    compilation_config = {\n        \"mode\": CompilationMode.VLLM_COMPILE,\n        \"compile_sizes\": [4, 8],\n        \"pass_config\": {\n            \"enable_sp\": True,\n            \"fuse_gemm_comms\": fuse_gemm_comms,\n            \"fuse_norm_quant\": fuse_norm_quant,\n            \"fuse_act_quant\": fuse_act_quant,\n            \"fuse_allreduce_rms\": False,\n            \"eliminate_noops\": True,\n            \"sp_min_token_num\": 0,\n        },\n        \"use_inductor_graph_partition\": use_inductor_graph_partition,\n    }\n    if not use_inductor_graph_partition:\n        compilation_config[\"splitting_ops\"] = []\n\n    tp_sp_args = [\n        *common_args,\n        \"--tensor-parallel-size\",\n        str(tp_size),\n        \"--pipeline-parallel-size\",\n        str(pp_size),\n        \"--distributed-executor-backend\",\n        distributed_backend,\n        \"--compilation_config\",\n        json.dumps(compilation_config),\n    ]\n\n    tp_args = [\n        *common_args,\n        \"--tensor-parallel-size\",\n        str(tp_size),\n        \"--distributed-executor-backend\",\n        \"mp\",\n    ]\n\n    compare_two_settings(\n        model_id,\n        tp_sp_args,\n        tp_args,\n        method=method,\n        force_v1_runner=True,\n    )\n\n\nSP_TEXT_GENERATION_MODELS = {\n    # [Decoder-only]\n    \"hmellor/tiny-random-LlamaForCausalLM\": SPTestSettings.fast(),\n    \"RedHatAI/Meta-Llama-3.1-8B-Instruct-FP8\": SPTestSettings.fp8_quant(),\n}\n\nSP_TEST_MODELS = [\n    # TODO support other models\n    # [LANGUAGE GENERATION]\n    \"hmellor/tiny-random-LlamaForCausalLM\",\n    \"RedHatAI/Meta-Llama-3.1-8B-Instruct-FP8\",\n]\n\n\n@pytest.mark.parametrize(\n    (\n        \"model_id\",\n        \"parallel_setup\",\n        \"distributed_backend\",\n        \"runner\",\n        \"test_options\",\n    ),\n    [\n        params\n        for model_id, settings in SP_TEXT_GENERATION_MODELS.items()\n        for params in settings.iter_params(model_id)\n        if model_id in SP_TEST_MODELS\n    ],\n)\n@pytest.mark.parametrize(\"use_inductor_graph_partition\", [True, False])\n@pytest.mark.parametrize(\"fuse_gemm_comms\", [False])  # TODO: enable async TP\n@create_new_process_for_each_test()\ndef test_tp_sp_generation(\n    model_id: str,\n    parallel_setup: ParallelSetup,\n    distributed_backend: str,\n    runner: RunnerOption,\n    test_options: SPTestOptions,\n    num_gpus_available,\n    use_inductor_graph_partition: bool,\n    fuse_gemm_comms: bool,\n):\n    if use_inductor_graph_partition and not is_torch_equal_or_newer(\"2.9.0.dev\"):\n        pytest.skip(\"inductor graph partition is only available in PyTorch 2.9+\")\n\n    # Skip FP8 SP-only test on sm89 (compute capability 8.9)\n    if (\n        \"fp8\" in model_id.lower()\n        and current_platform.get_device_capability() < (9, 0)\n        and (not fuse_gemm_comms)\n    ):\n        pytest.skip(\"FP8 reduction support begins with sm90 capable devices.\")\n\n    _compare_sp(\n        model_id,\n        parallel_setup,\n        distributed_backend,\n        runner,\n        test_options,\n        num_gpus_available,\n        use_inductor_graph_partition,\n        fuse_gemm_comms=fuse_gemm_comms,\n        enable_prompt_embeds=False,\n        method=\"generate\",\n        is_multimodal=False,\n    )\n\n\n# Focused regression test for the SP + prompt_embeds graph-rewrite path.\n# Covers pp_size=1 (SP only) and pp_size=2 (SP + PP); kept small on purpose so\n# we don't double the matrix of `test_tp_sp_generation` above.\nSP_PROMPT_EMBEDS_PARALLEL_SETUPS = [\n    ParallelSetup(\n        tp_size=2,\n        pp_size=pp_size,\n        fuse_norm_quant=False,\n        fuse_act_quant=False,\n        eager_mode=False,\n        chunked_prefill=False,\n    )\n    for pp_size in [1, 2]\n]\n\n\n@pytest.mark.parametrize(\"parallel_setup\", SP_PROMPT_EMBEDS_PARALLEL_SETUPS)\n@pytest.mark.parametrize(\"use_inductor_graph_partition\", [True, False])\n@create_new_process_for_each_test()\ndef test_tp_sp_generation_prompt_embeds(\n    parallel_setup: ParallelSetup,\n    num_gpus_available,\n    use_inductor_graph_partition: bool,\n):\n    if use_inductor_graph_partition and not is_torch_equal_or_newer(\"2.9.0.dev\"):\n        pytest.skip(\"inductor graph partition is only available in PyTorch 2.9+\")\n\n    _compare_sp(\n        \"hmellor/tiny-random-LlamaForCausalLM\",\n        parallel_setup,\n        distributed_backend=\"mp\",\n        runner=\"auto\",\n        test_options=SPTestOptions(multi_node_only=False, load_format=None),\n        num_gpus_available=num_gpus_available,\n        use_inductor_graph_partition=use_inductor_graph_partition,\n        fuse_gemm_comms=False,\n        enable_prompt_embeds=True,\n        method=\"generate\",\n        is_multimodal=False,\n    )\n\n\n@create_new_process_for_each_test()\ndef test_tp_sp_nvfp4_generation(num_gpus_available: int):\n    if (\n        not current_platform.is_cuda()\n        or not current_platform.is_device_capability_family(100)\n    ):\n        pytest.skip(\"NVFP4 requires Blackwell\")\n\n    _compare_sp(\n        NVFP4_MODEL_ID,\n        ParallelSetup(\n            tp_size=2,\n            pp_size=1,\n            fuse_norm_quant=True,\n            fuse_act_quant=True,\n            eager_mode=True,\n            chunked_prefill=False,\n        ),\n        \"mp\",\n        \"auto\",\n        SPTestOptions(\n            multi_node_only=False,\n            load_format=\"dummy\",\n            model_info=NVFP4_MODEL_INFO,\n        ),\n        num_gpus_available,\n        use_inductor_graph_partition=False,\n        fuse_gemm_comms=False,\n        enable_prompt_embeds=False,\n        method=\"generate\",\n        is_multimodal=False,\n        dtype=\"bfloat16\",\n    )\n","numLines":449,"startLine":1,"totalLines":449}}}
