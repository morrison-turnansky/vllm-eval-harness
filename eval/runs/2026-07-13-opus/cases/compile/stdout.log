{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_015w62nApzYBZgb68gzB3fFA","type":"tool_result","content":"1\t\"\"\"Structured output objects for the vLLM test oracle auditor.\"\"\"\n2\t\n3\timport json\n4\tfrom dataclasses import asdict, dataclass, field\n5\tfrom pathlib import Path\n6\t\n7\t\n8\t@dataclass\n9\tclass AuditCandidate:\n10\t    \"\"\"Phase 1 evidence for a single test candidate.\"\"\"\n11\t\n12\t    candidate: str\n13\t    file: str\n14\t    line: int\n15\t    comparison: str\n16\t    oracle: str\n17\t    helper: str\n18\t    batch_invariant_enabled: bool\n19\t    code_path_verified: bool\n20\t    fixtures: str\n21\t    c1_weak_oracle: str\n22\t    c2_realistic_breakage: str\n23\t    c3_no_strong_contract: str\n24\t    classification: str\n25\t    coincidentally_correct: bool\n26\t    code_snippet: str = \"\"\n27\t\n28\t\n29\t@dataclass\n30\tclass ReviewCandidate:\n31\t    \"\"\"Phase 2 review verdict for a single test candidate.\"\"\"\n32\t\n33\t    candidate: str\n34\t    phase_1_classification: str\n35\t    phase_1_coincidentally_correct: bool\n36\t    review: str\n37\t    file: str\n38\t    line: int\n39\t    comparison: str\n40\t    oracle: str\n41\t    helper: str\n42\t    batch_invariant_enabled: bool\n43\t    code_path_verified: bool\n44\t    fixtures: str\n45\t    c1_weak_oracle: str\n46\t    c2_realistic_breakage: str\n47\t    c3_no_strong_contract: str\n48\t    classification: str\n49\t    coincidentally_correct: bool\n50\t    code_snippet: str = \"\"\n51\t\n52\t\n53\t@dataclass\n54\tclass AuditReport:\n55\t    \"\"\"Full Phase 1 audit report.\"\"\"\n56\t\n57\t    test_files_in_scope: int\n58\t    candidates_analyzed: int\n59\t    candidates: list[AuditCandidate] = field(default_factory=list)\n60\t\n61\t    def verify_coverage(self, expected_tests: list[str]) -> None:\n62\t        \"\"\"Assert every test from list_tests.py output has a candidate entry.\n63\t\n64\t        Args:\n65\t            expected_tests: CSV lines from list_tests.py in DIR,FILE,FUNCTION format.\n66\t\n67\t        Raises:\n68\t            AssertionError: If any expected test is missing from the report.\n69\t        \"\"\"\n70\t        expected = set()\n71\t        for line in expected_tests:\n72\t            line = line.strip()\n73\t            if not line:\n74\t                continue\n75\t            parts = line.split(\",\")\n76\t            if len(parts) == 3:\n77\t                expected.add(parts[2])\n78\t        analyzed = {c.candidate for c in self.candidates}\n79\t        missing = expected - analyzed\n80\t        if missing:\n81\t            raise AssertionError(\n82\t                f\"Missing {len(missing)} test(s) from report:\\n\" + \"\\n\".join(sorted(missing))\n83\t            )\n84\t\n85\t    def write_split(self, cc_path: str, not_cc_path: str) -> None:\n86\t        \"\"\"Write CC and not-CC candidates to separate JSON files.\n87\t\n88\t        Verifies that cc + not_cc == total candidates before writing.\n89\t\n90\t        Args:\n91\t            cc_path: Output path for coincidentally correct candidates.\n92\t            not_cc_path: Output path for not coincidentally correct candidates.\n93\t\n94\t        Raises:\n95\t            AssertionError: If the split counts don't add up.\n96\t        \"\"\"\n97\t        cc = [c for c in self.candidates if c.coincidentally_correct]\n98\t        not_cc = [c for c in self.candidates if not c.coincidentally_correct]\n99\t\n100\t        if len(cc) + len(not_cc) != len(self.candidates):\n101\t            raise AssertionError(\n102\t                f\"Split mismatch: {len(cc)} CC + {len(not_cc)} not-CC \"\n103\t                f\"!= {len(self.candidates)} total\"\n104\t            )\n105\t\n106\t        cc_report = {\n107\t            \"test_files_in_scope\": self.test_files_in_scope,\n108\t            \"candidates_analyzed\": len(cc),\n109\t            \"candidates\": [asdict(c) for c in cc],\n110\t        }\n111\t        not_cc_report = {\n112\t            \"test_files_in_scope\": self.test_files_in_scope,\n113\t            \"candidates_analyzed\": len(not_cc),\n114\t            \"candidates\": [asdict(c) for c in not_cc],\n115\t        }\n116\t\n117\t        Path(cc_path).write_text(json.dumps(cc_report, indent=2) + \"\\n\")\n118\t        Path(not_cc_path).write_text(json.dumps(not_cc_report, indent=2) + \"\\n\")\n119\t\n120\t        print(\n121\t            f\"Total: {len(self.candidates)}, \"\n122\t            f\"CC: {len(cc)} -> {cc_path}, \"\n123\t            f\"Not CC: {len(not_cc)} -> {not_cc_path}\"\n124\t        )\n125\t\n126\t\n127\t@dataclass\n128\tclass ReviewReport:\n129\t    \"\"\"Full Phase 2 review report.\"\"\"\n130\t\n131\t    test_files_in_scope: int\n132\t    candidates_analyzed: int\n133\t    phase_1_agreed: int\n134\t    phase_1_reclassified: int\n135\t    candidates: list[ReviewCandidate] = field(default_factory=list)\n136\t\n137\t    def verify_coverage(self, cc_input_path: str) -> None:\n138\t        \"\"\"Assert every CC candidate from Phase 1 has a review entry.\n139\t\n140\t        Args:\n141\t            cc_input_path: Path to the Phase 1 CC JSON file.\n142\t\n143\t        Raises:\n144\t            AssertionError: If any CC candidate is missing a review.\n145\t        \"\"\"\n146\t        cc_data = json.loads(Path(cc_input_path).read_text())\n147\t        expected = {c[\"candidate\"] for c in cc_data[\"candidates\"]}\n148\t        reviewed = {c.candidate for c in self.candidates}\n149\t        missing = expected - reviewed\n150\t        if missing:\n151\t            raise AssertionError(\n152\t                f\"Missing {len(missing)} review(s):\\n\" + \"\\n\".join(sorted(missing))\n153\t            )\n154\t\n155\t    def write_to_file(self, file_name: str) -> None:\n156\t        \"\"\"Write report as JSON to the given file path.\n157\t\n158\t        Args:\n159\t            file_name: Output file path.\n160\t        \"\"\"\n161\t        Path(file_name).write_text(json.dumps(asdict(self), indent=2) + \"\\n\")\n162\t"}]},"parent_tool_use_id":null,"session_id":"603f2b8b-1633-4397-a4a3-f9f63565a548","uuid":"4193ac7a-e86e-4f56-b3ab-fdc14e0bbc3d","timestamp":"2026-07-13T16:45:03.867Z","tool_use_result":{"type":"text","file":{"filePath":"/home/devuser/projects/ai-marketplace/vllm-test-audit/scripts/output_object.py","content":"\"\"\"Structured output objects for the vLLM test oracle auditor.\"\"\"\n\nimport json\nfrom dataclasses import asdict, dataclass, field\nfrom pathlib import Path\n\n\n@dataclass\nclass AuditCandidate:\n    \"\"\"Phase 1 evidence for a single test candidate.\"\"\"\n\n    candidate: str\n    file: str\n    line: int\n    comparison: str\n    oracle: str\n    helper: str\n    batch_invariant_enabled: bool\n    code_path_verified: bool\n    fixtures: str\n    c1_weak_oracle: str\n    c2_realistic_breakage: str\n    c3_no_strong_contract: str\n    classification: str\n    coincidentally_correct: bool\n    code_snippet: str = \"\"\n\n\n@dataclass\nclass ReviewCandidate:\n    \"\"\"Phase 2 review verdict for a single test candidate.\"\"\"\n\n    candidate: str\n    phase_1_classification: str\n    phase_1_coincidentally_correct: bool\n    review: str\n    file: str\n    line: int\n    comparison: str\n    oracle: str\n    helper: str\n    batch_invariant_enabled: bool\n    code_path_verified: bool\n    fixtures: str\n    c1_weak_oracle: str\n    c2_realistic_breakage: str\n    c3_no_strong_contract: str\n    classification: str\n    coincidentally_correct: bool\n    code_snippet: str = \"\"\n\n\n@dataclass\nclass AuditReport:\n    \"\"\"Full Phase 1 audit report.\"\"\"\n\n    test_files_in_scope: int\n    candidates_analyzed: int\n    candidates: list[AuditCandidate] = field(default_factory=list)\n\n    def verify_coverage(self, expected_tests: list[str]) -> None:\n        \"\"\"Assert every test from list_tests.py output has a candidate entry.\n\n        Args:\n            expected_tests: CSV lines from list_tests.py in DIR,FILE,FUNCTION format.\n\n        Raises:\n            AssertionError: If any expected test is missing from the report.\n        \"\"\"\n        expected = set()\n        for line in expected_tests:\n            line = line.strip()\n            if not line:\n                continue\n            parts = line.split(\",\")\n            if len(parts) == 3:\n                expected.add(parts[2])\n        analyzed = {c.candidate for c in self.candidates}\n        missing = expected - analyzed\n        if missing:\n            raise AssertionError(\n                f\"Missing {len(missing)} test(s) from report:\\n\" + \"\\n\".join(sorted(missing))\n            )\n\n    def write_split(self, cc_path: str, not_cc_path: str) -> None:\n        \"\"\"Write CC and not-CC candidates to separate JSON files.\n\n        Verifies that cc + not_cc == total candidates before writing.\n\n        Args:\n            cc_path: Output path for coincidentally correct candidates.\n            not_cc_path: Output path for not coincidentally correct candidates.\n\n        Raises:\n            AssertionError: If the split counts don't add up.\n        \"\"\"\n        cc = [c for c in self.candidates if c.coincidentally_correct]\n        not_cc = [c for c in self.candidates if not c.coincidentally_correct]\n\n        if len(cc) + len(not_cc) != len(self.candidates):\n            raise AssertionError(\n                f\"Split mismatch: {len(cc)} CC + {len(not_cc)} not-CC \"\n                f\"!= {len(self.candidates)} total\"\n            )\n\n        cc_report = {\n            \"test_files_in_scope\": self.test_files_in_scope,\n            \"candidates_analyzed\": len(cc),\n            \"candidates\": [asdict(c) for c in cc],\n        }\n        not_cc_report = {\n            \"test_files_in_scope\": self.test_files_in_scope,\n            \"candidates_analyzed\": len(not_cc),\n            \"candidates\": [asdict(c) for c in not_cc],\n        }\n\n        Path(cc_path).write_text(json.dumps(cc_report, indent=2) + \"\\n\")\n        Path(not_cc_path).write_text(json.dumps(not_cc_report, indent=2) + \"\\n\")\n\n        print(\n            f\"Total: {len(self.candidates)}, \"\n            f\"CC: {len(cc)} -> {cc_path}, \"\n            f\"Not CC: {len(not_cc)} -> {not_cc_path}\"\n        )\n\n\n@dataclass\nclass ReviewReport:\n    \"\"\"Full Phase 2 review report.\"\"\"\n\n    test_files_in_scope: int\n    candidates_analyzed: int\n    phase_1_agreed: int\n    phase_1_reclassified: int\n    candidates: list[ReviewCandidate] = field(default_factory=list)\n\n    def verify_coverage(self, cc_input_path: str) -> None:\n        \"\"\"Assert every CC candidate from Phase 1 has a review entry.\n\n        Args:\n            cc_input_path: Path to the Phase 1 CC JSON file.\n\n        Raises:\n            AssertionError: If any CC candidate is missing a review.\n        \"\"\"\n        cc_data = json.loads(Path(cc_input_path).read_text())\n        expected = {c[\"candidate\"] for c in cc_data[\"candidates\"]}\n        reviewed = {c.candidate for c in self.candidates}\n        missing = expected - reviewed\n        if missing:\n            raise AssertionError(\n                f\"Missing {len(missing)} review(s):\\n\" + \"\\n\".join(sorted(missing))\n            )\n\n    def write_to_file(self, file_name: str) -> None:\n        \"\"\"Write report as JSON to the given file path.\n\n        Args:\n            file_name: Output file path.\n        \"\"\"\n        Path(file_name).write_text(json.dumps(asdict(self), indent=2) + \"\\n\")\n","numLines":162,"startLine":1,"totalLines":162}}}
